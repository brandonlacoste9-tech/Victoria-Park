# Netlify production env — paste in UI or: netlify env:import netlify.env
# Site: https://justbookme.ca

# REQUIRED
NEXT_PUBLIC_SUPABASE_URL=https://ulbfaxhsbbckotcbmslk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=https://justbookme.ca
NEXT_PUBLIC_CONTACT_EMAIL=info@justbookme.ca

# TWILIO SMS (all 3 required to send from production)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# CRON (required for scheduled reminders + usage rollup on Netlify)
CRON_SECRET=

# Usage enforcement — set true to pause outbound SMS at 200% of plan SMS limit (inbound voice unaffected)
# USAGE_ENFORCE=false

# OPTIONAL — Stripe, Vapi, etc. (see docs/NETLIFY_DEPLOY.md)
# NEXT_PUBLIC_CALENDLY_URL=
# TWILIO_MESSAGING_SERVICE_SID=

# DO NOT ADD: DATABASE_URL, OLLAMA_*, OAuth OQ client id/secret, TWILIO_API_KEY_*